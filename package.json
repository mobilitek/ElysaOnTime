{
  "name": "elysia-ontime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:api": "bun --watch src/index.ts",
    "dev:web": "vite --config vite.config.ts",
    "build:web": "vite build --config vite.config.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:integration": "RUN_INTEGRATION_TESTS=1 bun test",
    "typecheck": "bunx tsc --noEmit",
    "user:create": "bun src/commands/create-user.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.23",
    "exceljs": "^4.4.0",
    "postgres": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.0",
    "vite": "^8.1.5"
  }
}

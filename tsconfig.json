{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types", "vite/client"]
  },
  "include": ["src/**/*.ts", "web/src/**/*.ts", "web/src/**/*.tsx", "vite.config.ts"]
}
